{
    "template": false,
    "puzzle": {
        // templates can have any properties of the puzzle object
        // template is optional
        "template": "file/path/from/root",
        // if template is given, cell_count and cell_layout are not allowed (I think)
        // we could also just add to the template
        "cell_count": 81,
        "cell_layout": [{"x":0,"y":0}],
        "symbols": "Symbols9", // should be a definition in already in lean, no custom arrays.
        "imported_constraints": {
            // all constraints must have unique names.
            // for the sake of lean and structure:
            //    constraints in template will be imported as template.constraint
            //    any here will be imported as diags.constraint
            "diags": "9x9_diagonals.suko_constraint"
        },
        "constraints": {
            // for lean, any constraints here are just name
            "name": "UniqueSet f {1,2,3}",
            // I think we can allow this too, but I still want to enforce the unique surface names
            // maybe something will change my mind
            "pack": {
                "c1": "lean code",
                "c2": "lean code"
            }
        }
    },
    "proof_state": "in_progress", // complete, in_progress, and not_started
    "proof": [
        "naked_single 5 2",
        "proof step"
    ]
}
